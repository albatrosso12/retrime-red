# ==========================================
# ENVIRONMENT VARIABLES FOR BALKAN CONFLICT RULES
# Copy this to .env in the root for frontend (Vite will read it)
# ==========================================

# --- Frontend (Cloudflare Pages) ---
# This is your Cloudflare Worker URL (the backend)
VITE_API_URL=https://retrime.korsetov2009.workers.dev

# Discord OAuth variables for frontend (NOT USED NOW - Worker handles it)
# These are just for reference, remove if you want:
# VITE_DISCORD_CLIENT_ID=1499936916127088793
# VITE_DISCORD_REDIRECT_URI=https://retrime.korsetov2009.workers.dev/auth/discord/callback

# --- Cloudflare Worker (Backend) ---
# These are set via `wrangler secret put` (NOT in this file!)
# DISCORD_CLIENT_ID=1499936916127088793
# DISCORD_CLIENT_SECRET=your_secret_here
# DISCORD_REDIRECT_URI=https://retrime.korsetov2009.workers.dev/auth/discord/callback
# ZAP_URL=https://hooks.zapier.com/hooks/c/...

# --- Cloudflare D1 Database ---
# Automatically created via `wrangler d1 create balkan-rules-db`
# No need to set URL - it's a binding in wrangler.toml
