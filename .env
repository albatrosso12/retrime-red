# ==========================================
# ENVIRONMENT VARIABLES FOR BALKAN CONFLICT RULES
# Copy this to .env in the root for frontend (Vite will read it)
# ==========================================

# --- Frontend (Cloudflare Pages) ---
# This is your Cloudflare Worker URL (the backend)
VITE_API_URL=https://retrime.korsetov2009.workers.dev

# Discord OAuth - for direct redirect to Discord (handled by Worker)
# Get these from https://discord.com/developers/applications
VITE_DISCORD_CLIENT_ID=1499936916127088793
VITE_DISCORD_REDIRECT_URI=https://retrime.korsetov2009.workers.dev/auth/discord/callback
# --- Cloudflare Worker (Backend) ---
# These are set in wrangler.toml or via `wrangler secret put`
# DISCORD_CLIENT_ID=your_discord_client_id
# DISCORD_CLIENT_SECRET=your_discord_client_secret
# DISCORD_REDIRECT_URI=https://discord.com/oauth2/authorize?client_id=1499936916127088793&response_type=code&redirect_uri=https%3A%2F%2Fretrime.korsetov2009.workers.dev%2Fauth%2Fdiscord%2Fcallback&scope=identify+email+guilds.join
# ZAP_URL=https://hooks.zapier.com/hooks/c/your-webhook-url

# --- Cloudflare D1 Database ---
# Automatically created via `wrangler d1 create balkan-rules-db`
# No need to set URL - it's a binding in wrangler.toml
