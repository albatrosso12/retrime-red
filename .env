# ==========================================
# ENVIRONMENT VARIABLES FOR BALKAN CONFLICT RULES
# Copy to .env in root for frontend (Vite will read it)
# ==========================================

# --- Frontend (Cloudflare Pages) ---
# This is your Cloudflare Worker URL (the backend)
VITE_API_URL=https://retrime.korsetov2009.workers.dev

# --- Cloudflare Worker (Backend) ---
# These are set in wrangler.toml or via `wrangler secret put`
# DISCORD_CLIENT_ID=your_discord_client_id
# DISCORD_CLIENT_SECRET=your_discord_client_secret  
# DISCORD_REDIRECT_URI=https://retrime.korsetov2009.workers.dev/auth/discord/callback
# ZAP_URL=https://hooks.zapier.com/hooks/c/your-webhook-url

# --- Cloudflare D1 Database ---
# Automatically created via `wrangler d1 create balkan-rules-db`
# No need to set URL - it's a binding in wrangler.toml
